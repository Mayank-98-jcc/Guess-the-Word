{
  "name": "imposter-who",
  "private": true,
  "version": "1.0.0",
  "description": "A social word-guessing game packaged as a macOS desktop app.",
  "author": "Mayank Thapliyal",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "react-start": "vite --host localhost --port 3000 --strictPort",
    "electron-start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "start": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && npm run electron-start\"",
    "build": "vite build",
    "preview": "vite preview",
    "build-electron": "npm run build && electron-builder"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "framer-motion": "^11.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.18",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.game.app",
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "main.js"
    ]
  }
}
